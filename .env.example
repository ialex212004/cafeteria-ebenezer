# ============================================================
#  CAFETERÍA EBENEZER — Configuración de Entorno
# ============================================================
#
# Copia este archivo a .env y configura los valores reales
# No commits .env al repositorio (está en .gitignore)
#

# ── SERVIDOR ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── BASE DE DATOS (Opcional — para versión futura con DB) ─
# DATABASE_URL=postgresql://user:password@localhost:5432/cafeteria
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=cafeteria_user
# DB_PASSWORD=secure_password
# DB_NAME=cafeteria_db

# ── SEGURIDAD ─────────────────────────────────────────────
JWT_SECRET=tu_super_secreto_jwt_aqui_min_32_caracteres
API_KEY=tu_api_key_para_endpoints_protegidos

# ── CORS ──────────────────────────────────────────────────
# Dominios permitidos (separados por comas)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://cafeteria-ebenezer.com

# ── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── LOGGING ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── EMAIL (Opcional — para confirmaciones) ───────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASSWORD=tu_contrasena_app
# SMTP_FROM=noreply@cafeteria-ebenezer.com

# ── NOTIFICACIONES ────────────────────────────────────────
# ADMIN_EMAIL=admin@cafeteria-ebenezer.com
# ADMIN_PHONE=+34123456789
# SEND_NOTIFICATIONS=true

# ── MONITOREO ─────────────────────────────────────────────
# SENTRY_DSN=https://seu_dsn_aqui@sentry.io/project_id
# ANALYTICS_ENABLED=true
