# ============================================================
#  VERCEL DEPLOYMENT - Environment Variables
# ============================================================

# Node environment
NODE_ENV=production

# Server
PORT=3000
HOST=0.0.0.0

# Database (Phase 9: PostgreSQL)
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=cafeteria_ebenezer
DB_USER=
DB_PASSWORD=

# JWT (Phase 8: Authentication)
JWT_SECRET=
JWT_EXPIRE=7d

# Email (Phase 10: Notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cafeteriaebenezer.com

# Payment (Phase 11: Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Frontend
VITE_API_URL=https://yourdomain.vercel.app/api
VITE_ENV=production

# CORS
CORS_ORIGIN=https://yourdomain.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_PEDIDOS_MAX=10
RATE_LIMIT_RESENAS_MAX=20
