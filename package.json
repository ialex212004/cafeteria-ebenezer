{
  "name": "cafeteria-ebenezer",
  "version": "1.0.0",
  "description": "Cafetería Ebenezer - Plataforma web completa con pedidos y reseñas",
  "main": "server.js",
  "type": "commonjs",
  "author": "Cafetería Ebenezer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ialex212004/Cafeteria-Ebenezer.git"
  },
  "scripts": {
    "start": "next start",
    "dev": "next dev",
    "build": "next build",
    "dev:api": "NODE_ENV=development node server.js",
    "start:api": "node server.js",
    "test": "NODE_ENV=test jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "validate": "npm run lint && npm run test",
    "logs:clear": "rm -rf logs/*.log",
    "vercel-build": "next build",
    "vercel-dev": "vercel dev"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.23",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.38",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "cafeteria",
    "restaurant",
    "express",
    "api",
    "nodejs"
  ],
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/cafeteria-ebenezer/"
    ]
  }
}
