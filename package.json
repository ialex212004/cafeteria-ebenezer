{
  "name": "cafeteria-ebenezer",
  "version": "1.0.0",
  "description": "Cafetería Ebenezer - Plataforma web completa con pedidos y reseñas",
  "main": "server.js",
  "type": "commonjs",
  "author": "Cafetería Ebenezer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ialex212004/Cafeteria-Ebenezer.git"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "concurrently -n backend,frontend \"npm run dev:api\" \"npm run dev:client\"",
    "build": "npm run build:client",
    "dev:api": "NODE_ENV=development node server.js",
    "dev:client": "npm --prefix cafeteria-ebenezer run dev",
    "build:client": "npm --prefix cafeteria-ebenezer install && npm --prefix cafeteria-ebenezer run build",
    "preview:client": "npm --prefix cafeteria-ebenezer run start",
    "test": "NODE_ENV=test jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "validate": "npm run lint && npm run test",
    "logs:clear": "rm -rf logs/*.log",
    "vercel-build": "npm run build:client",
    "vercel-dev": "vercel dev"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.3.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "shadcn": "^4.4.0"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "keywords": [
    "cafeteria",
    "restaurant",
    "express",
    "api",
    "nodejs"
  ],
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/cafeteria-ebenezer/"
    ]
  }
}
